# ====================
# PhotoSet Docker 运行环境配置
# 复制为 .env.docker 并修改
# ====================

# ====================
# 数据库配置 (使用 MySQL 服务名)
# ====================
DB_HOST=mysql
DB_PORT=3306
DB_USER=photoset
DB_PASSWORD=photoset123
DB_NAME=photoset
DB_CHARSET=utf8mb4

# ====================
# Redis 配置 (使用 Redis 服务名)
# ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ====================
# 应用配置
# ====================
APP_NAME=PhotoSet
APP_ENV=production
APP_PORT=8080
APP_KEY=photoSetSecretKey1234567890123456

# ====================
# JWT 配置 (生产环境务必修改这个密钥)
# ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=24h

# ====================
# 存储配置
# ====================
# 存储类型: local|r2 (local: 本地卷, r2: Cloudflare R2)
STORAGE_TYPE=local

# ====================
# 本地存储配置 (Docker 卷)
# ====================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=50

# ====================
# Cloudflare R2 配置 (当 STORAGE_TYPE=r2 时生效)
# ====================
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key-id
# R2_SECRET_ACCESS_KEY=your-secret-access-key
# R2_REGION=auto
# R2_BUCKET_NAME=photoset-uploads
# R2_PUBLIC_URL=https://your-public-cdn-domain.com

# ====================
# URL 签名配置 (生产环境修改)
# ====================
SIGN_SECRET=your-url-sign-secret-change-this-in-production
SIGN_EXPIRE=3600

# ====================
# 支付宝支付配置 (按需配置)
# ====================
# ALIPAY_APP_ID=your-app-id
# ALIPAY_PRIVATE_KEY=your-private-key
# ALIPAY_PUBLIC_KEY=your-public-key
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ====================
# 安全配置
# ====================
CORS_ALLOW_ORIGINS=http://frontend:80,http://admin:80
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ====================
# 缓存配置
# ====================
CACHE_ENABLED=true
CACHE_PHOTOSET_LIST_TTL=300      # 5分钟
CACHE_PHOTOSET_DETAIL_TTL=600    # 10分钟
CACHE_TAGS_TTL=1800              # 30分钟

# ====================
# 搜索配置
# ====================
SEARCH_ENABLED=true
SEARCH_MIN_KEYWORD_LENGTH=1
SEARCH_MAX_RESULTS=50

# ====================
# 日志与监控
# ====================
DEBUG=false
LOG_LEVEL=info
LOG_FORMAT=json