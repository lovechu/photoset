# PhotoSet 后端 - 环境变量配置示例

# ====================
# 数据库配置
# ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=photoset
DB_PASSWORD=photoset123
DB_NAME=photoset
DB_CHARSET=utf8mb4

# ====================
# Redis 配置
# ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ====================
# 应用配置
# ====================
APP_NAME=PhotoSet
APP_ENV=development
APP_PORT=8080
APP_KEY=photoSetSecretKey1234567890123456

# ====================
# JWT 配置
# ====================
JWT_SECRET=jwtSecretKey123456789012345678901234567890
JWT_EXPIRE=24h

# ====================
# 存储配置
# ====================
# 存储类型: local|r2 (local: 本地文件系统, r2: Cloudflare R2)
STORAGE_TYPE=local

# ====================
# 本地存储配置
# ====================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=50

# ====================
# Cloudflare R2 配置 (当 STORAGE_TYPE=r2 时生效)
# ====================
# 参考: https://developers.cloudflare.com/r2/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_BUCKET_NAME=photoset-uploads
R2_PUBLIC_URL=

# ====================
# URL 签名配置
# ====================
SIGN_SECRET=urlSignSecret123456789012345678901234567
SIGN_EXPIRE=3600

# ====================
# 支付宝支付配置
# ====================
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# ====================
# 安全配置
# ====================
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ====================
# 缓存配置
# ====================
CACHE_ENABLED=true
CACHE_PHOTOSET_LIST_TTL=300      # 套图列表缓存 5 分钟
CACHE_PHOTOSET_DETAIL_TTL=600    # 套图详情缓存 10 分钟
CACHE_TAGS_TTL=1800              # 标签缓存 30 分钟

# ====================
# 搜索配置
# ====================
SEARCH_ENABLED=true
SEARCH_MIN_KEYWORD_LENGTH=1
SEARCH_MAX_RESULTS=50

# ====================
# 开发工具配置
# ====================
DEBUG=true
LOG_LEVEL=info